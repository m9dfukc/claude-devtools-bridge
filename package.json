{
    "name": "claude-devtools-bridge",
    "version": "0.1.1",
    "description": "MCP devtools bridge — lets Claude inspect and mutate live application state via WebSocket",
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/client/index.d.ts",
            "import": "./dist/client/index.js"
        },
        "./server": {
            "types": "./dist/server/mcp-server.d.ts",
            "import": "./dist/server/mcp-server.js"
        }
    },
    "bin": {
        "devtools-server": "./dist/server/mcp-server.js"
    },
    "files": [
        "dist",
        "skills",
        ".claude-plugin",
        ".mcp.json"
    ],
    "scripts": {
        "build": "tsc -p tsconfig.client.json && tsc -p tsconfig.server.json --noEmit && node build-server.js",
        "typecheck": "tsc -p tsconfig.client.json --noEmit && tsc -p tsconfig.server.json --noEmit",
        "devtools": "tsx src/server/mcp-server.ts"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.27.0",
        "ws": "^8.18.0",
        "zod": "^3.24.0"
    },
    "devDependencies": {
        "@types/ws": "^8.18.0",
        "esbuild": "^0.25.0",
        "tsx": "^4.19.0",
        "typescript": "^5.8.0"
    },
    "keywords": [
        "mcp",
        "devtools",
        "claude",
        "state-inspection",
        "debugging"
    ],
    "license": "MIT"
}
